# Makro Dla Gastronomii credentials (the same login you use on dlagastronomii.makro.pl)
MAKRO_USER_ID=you@example.com
MAKRO_PASSWORD=your-password

# Optional overrides (auto-discovered from the JWT / carts list when omitted)
# MAKRO_COUNTRY=PL
# MAKRO_LOCALE=pl-PL
# MAKRO_STORE_ID=00401
# MAKRO_FSD_ADDRESS_ID=<your-delivery-address-id>

# Login method: "browser" (default, passes Akamai via Playwright) or "direct"
# MAKRO_LOGIN_METHOD=browser
# MAKRO_HEADLESS=1   # set 0 to watch the login browser

# Where the session (cookies + JWT) is persisted. CLI default: ~/.makroify
# On Vercel use a writable path like /tmp/.makroify
# MAKROIFY_HOME=/custom/path

# ---------------------------------------------------------------------------
# Eve agent (agent/) — the .env decides what runs and which Makro account it uses
# ---------------------------------------------------------------------------
# Model the agent runs (Vercel AI Gateway model id). Defaults to a cheap one.
# EVE_MODEL=anthropic/claude-haiku-4.5

# One model credential is required (pick one):
# AI_GATEWAY_API_KEY=...        # Vercel AI Gateway
# ANTHROPIC_API_KEY=...         # direct Anthropic

# Discord GATEWAY bot (bot/index.ts, `npm run bot`) — reads normal channel
# messages so the team can chat naturally. No public URL/tunnel needed (outbound
# WebSocket). Requires the Bot Token + the privileged Message Content intent.
# DISCORD_BOT_TOKEN=...              # Developer Portal → Bot → Reset Token
# DISCORD_WATCH_CHANNEL_ID=...       # channel(s) the bot watches (comma-separated);
#                                    # it also answers @mentions anywhere
# DISCORD_REMINDER_CHANNEL_ID=...    # daily 20:00 reminder (defaults to first watched)
# EVE_BASE_URL=http://127.0.0.1:2000 # where the Eve agent HTTP API runs
# MAKRO_TENANT_ID=default            # tenant id (see bot/tenants.ts for multi-tenant)
