{
  "name": "makroify",
  "version": "0.1.0",
  "description": "TypeScript client + CLI for the Makro Dla Gastronomii (dlagastronomii.makro.pl) ordering API",
  "type": "module",
  "license": "MIT",
  "bin": {
    "makroify": "./dist/cli/index.js"
  },
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    }
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "cli": "tsx src/cli/index.ts",
    "agent": "eve dev",
    "bot": "tsx bot/index.ts",
    "agent:info": "eve info",
    "agent:build": "eve build",
    "agent:start": "eve start",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ai": "^7.0.0-beta.178",
    "commander": "^12.1.0",
    "discord.js": "^14.26.4",
    "eve": "^0.12.0",
    "tough-cookie": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=24"
  }
}
