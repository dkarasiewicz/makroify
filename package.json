{
  "name": "makroify",
  "version": "0.1.0",
  "description": "TypeScript client + CLI for the Makro Dla Gastronomii (dlagastronomii.makro.pl) ordering API",
  "type": "module",
  "license": "MIT",
  "bin": {
    "makroify": "./dist/cli/index.js"
  },
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./eve": {
      "types": "./dist/eve/tools.d.ts",
      "import": "./dist/eve/tools.js"
    }
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "cli": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "tough-cookie": "^5.0.0"
  },
  "optionalDependencies": {
    "playwright": "^1.61.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "playwright": "^1.61.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
